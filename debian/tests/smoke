#!/bin/sh
set -e

# Verify the binaries are installed and report their versions
clnkr --version
clnkrd --version

# Verify it exits with error when no API key is set
unset CLNKR_API_KEY
unset ANTHROPIC_API_KEY
if clnkr -p "test" 2>/dev/null; then
    echo "FAIL: clnkr should exit with error when no API key is set"
    exit 1
fi

echo "OK: smoke tests passed"
