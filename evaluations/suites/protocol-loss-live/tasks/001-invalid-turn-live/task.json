{
  "id": "001-invalid-turn-live",
  "instruction_file": "input/instruction.txt",
  "working_directory": ".",
  "full_send": true,
  "step_limit": 3,
  "mode": "live-provider",
  "graders": {
    "outcome_diff": {
      "enabled": true,
      "required": true
    },
    "outcome_command_output": {
      "enabled": true,
      "required": true,
      "command": [
        "bash",
        "-lc",
        "actual=$(cat note.txt); [ \"$actual\" = \"hello\" ] && printf '%s\\n' \"$actual\""
      ],
      "expected_exit_code": 0,
      "stdout_contains": [
        "hello"
      ]
    },
    "transcript_command_trace": {
      "enabled": true,
      "required": false,
      "expected_exit_codes": [
        0
      ],
      "max_command_count": 3
    }
  }
}
